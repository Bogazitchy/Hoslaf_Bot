<service>
  <id>HoslafBot</id>
  <name>Hoslaf Discord Bot</name>
  <description>Runs the Hoslaf Discord bot in the background and restarts it if it exits.</description>

  <executable>powershell.exe</executable>
  <arguments>-NoProfile -ExecutionPolicy Bypass -File "%BASE%\run_hoslafbot_service.ps1"</arguments>
  <workingdirectory>%BASE%</workingdirectory>

  <env name="PYTHONUNBUFFERED" value="1" />
  <env name="PYTHONIOENCODING" value="utf-8" />
  <env name="PATH" value="%BASE%;%PATH%" />

  <startmode>Automatic</startmode>
  <delayedAutoStart>true</delayedAutoStart>
  <onfailure action="restart" delay="10 sec" />
  <onfailure action="restart" delay="30 sec" />
  <onfailure action="restart" delay="60 sec" />

  <logpath>%BASE%\logs</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10485760</sizeThreshold>
    <keepFiles>8</keepFiles>
  </log>
</service>
